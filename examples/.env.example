# =============================================================================
# PROMPTHEUS MULTI-USER PLATFORM - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!
# =============================================================================

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# For Docker Compose: Use service name 'postgres' as host
# For local dev: Use 'localhost'
DATABASE_URL=postgresql://promptheus:dev_password_change_in_prod@postgres:5432/promptheus

# Database pool settings (optional)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=0

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# Redis connection string for caching and rate limiting
# Format: redis://[password@]host:port/database
REDIS_URL=redis://:dev_redis_password@redis:6379/0

# Redis settings
REDIS_MAX_CONNECTIONS=50
REDIS_DECODE_RESPONSES=true

# =============================================================================
# JWT & AUTHENTICATION
# =============================================================================
# Secret key for JWT token signing (MUST be 32+ characters in production)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=dev_secret_key_CHANGE_IN_PRODUCTION_minimum_32_chars_long

# JWT algorithm
ALGORITHM=HS256

# Token expiration times
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Password hashing
PASSWORD_MIN_LENGTH=12
BCRYPT_ROUNDS=12

# =============================================================================
# CORS (Cross-Origin Resource Sharing)
# =============================================================================
# Comma-separated list of allowed origins
# Development: Include both React dev servers (Vite, CRA)
# Production: Only your production domain
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:80

# =============================================================================
# LLM PROVIDER API KEYS (from existing Promptheus)
# =============================================================================
# Get your API keys from:
# Google Gemini: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Groq: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Alibaba Cloud Qwen: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_qwen_api_key_here

# Zhipu AI GLM: https://open.bigmodel.cn/
ZAI_API_KEY=your_glm_api_key_here

# Default provider and model
DEFAULT_PROVIDER=gemini
DEFAULT_MODEL=gemini-2.0-flash-exp

# =============================================================================
# EMAIL CONFIGURATION (Optional - for verification emails)
# =============================================================================
# SMTP server settings
# For Gmail: Enable "App Passwords" in your Google account settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_TLS=true
SMTP_SSL=false

# Email sender
EMAIL_FROM=noreply@promptheus.dev
EMAIL_FROM_NAME=Promptheus

# Email templates directory
EMAIL_TEMPLATES_DIR=./app/email-templates

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
# Environment: development, staging, production
ENVIRONMENT=development

# Debug mode (verbose logging, detailed errors)
DEBUG=true

# Application name and version
APP_NAME=Promptheus
APP_VERSION=2.0.0

# API base path
API_V1_PREFIX=/api/v1

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
# Backend API URL (from frontend perspective)
REACT_APP_API_URL=http://localhost:8000

# WebSocket URL (for real-time features - Phase 2)
REACT_APP_WS_URL=ws://localhost:8000

# Frontend settings
NODE_ENV=development
WATCHPACK_POLLING=true

# =============================================================================
# RATE LIMITING
# =============================================================================
# Requests per minute by user tier
RATE_LIMIT_FREE=10
RATE_LIMIT_AUTHENTICATED=100
RATE_LIMIT_TEAM=1000
RATE_LIMIT_ENTERPRISE=0  # 0 = unlimited

# Rate limit window (seconds)
RATE_LIMIT_WINDOW=60

# =============================================================================
# USAGE LIMITS
# =============================================================================
# Monthly prompt limits by plan
LIMIT_FREE_PROMPTS=100
LIMIT_TEAM_PROMPTS=10000
LIMIT_ENTERPRISE_PROMPTS=0  # 0 = unlimited

# API call limits per month
LIMIT_FREE_API_CALLS=1000
LIMIT_TEAM_API_CALLS=50000
LIMIT_ENTERPRISE_API_CALLS=0

# =============================================================================
# FILE STORAGE (Phase 2 - for prompt attachments, exports)
# =============================================================================
# Storage backend: local, s3, gcs
STORAGE_BACKEND=local

# Local storage path
STORAGE_LOCAL_PATH=./storage

# AWS S3 configuration (if using S3)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=promptheus-storage
AWS_S3_REGION=us-east-1

# =============================================================================
# MONITORING & LOGGING
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json, text
LOG_FORMAT=json

# Log file path (empty = stdout only)
LOG_FILE=

# Sentry DSN (for error tracking - optional)
SENTRY_DSN=

# Sentry environment
SENTRY_ENVIRONMENT=development

# =============================================================================
# SECURITY
# =============================================================================
# Enable HTTPS redirect (production only)
HTTPS_REDIRECT=false

# Trusted hosts (comma-separated)
TRUSTED_HOSTS=localhost,127.0.0.1

# Session cookie settings
SESSION_COOKIE_SECURE=false  # true in production
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=lax

# CSRF protection
CSRF_ENABLED=true
CSRF_SECRET=your_csrf_secret_key

# =============================================================================
# OKTA INTEGRATION (Phase 3 - Enterprise)
# =============================================================================
# OKTA domain and credentials
OKTA_DOMAIN=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_REDIRECT_URI=http://localhost:8000/api/v1/auth/okta/callback

# OKTA settings
OKTA_ISSUER=
OKTA_AUDIENCE=

# =============================================================================
# OAUTH2 PROVIDERS (Phase 2)
# =============================================================================
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback

# Microsoft Azure AD
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_REDIRECT_URI=http://localhost:8000/api/v1/auth/azure/callback

# =============================================================================
# BACKGROUND JOBS (Phase 2 - Celery/RQ)
# =============================================================================
# Celery broker URL
CELERY_BROKER_URL=redis://:dev_redis_password@redis:6379/1

# Celery result backend
CELERY_RESULT_BACKEND=redis://:dev_redis_password@redis:6379/2

# =============================================================================
# ANALYTICS (Phase 2)
# =============================================================================
# Google Analytics
GA_TRACKING_ID=

# Mixpanel
MIXPANEL_TOKEN=

# PostHog
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# =============================================================================
# PAYMENT PROCESSING (Phase 3 - Monetization)
# =============================================================================
# Stripe
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Pricing (USD cents per month)
PRICE_FREE=0
PRICE_TEAM=4900  # $49.00
PRICE_ENTERPRISE=19900  # $199.00

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable/disable features
FEATURE_OAUTH_LOGIN=false
FEATURE_TEAM_COLLABORATION=true
FEATURE_API_KEYS=true
FEATURE_PROMPT_SHARING=false
FEATURE_EXPORT_HISTORY=false
FEATURE_WEBHOOKS=false

# =============================================================================
# DEVELOPMENT TOOLS
# =============================================================================
# pgAdmin credentials (dev only)
PGADMIN_DEFAULT_EMAIL=admin@promptheus.dev
PGADMIN_DEFAULT_PASSWORD=admin

# Swagger UI (API docs)
ENABLE_SWAGGER=true
SWAGGER_URL=/docs

# =============================================================================
# NOTES
# =============================================================================
# - Never commit this file with real credentials
# - Use different secrets for development, staging, and production
# - Rotate secrets regularly (every 90 days recommended)
# - Store production secrets in AWS Secrets Manager, HashiCorp Vault, etc.
# - Minimum SECRET_KEY length: 32 characters
# - Use strong passwords (12+ chars, mixed case, numbers, symbols)
# =============================================================================
